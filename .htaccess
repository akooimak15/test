# ============================================================
# .htaccess — セキュリティ設定
# （Apache / Termux上のhttpdで有効）
# ============================================================

Options -Indexes
Options -MultiViews

# dataディレクトリへの直接アクセスを拒否
<IfModule mod_rewrite.c>
    RewriteEngine On

    # dataフォルダへのアクセス禁止
    RewriteRule ^data/ - [F,L]
</IfModule>

# .envや設定ファイルへのアクセス禁止
<FilesMatch "\.(env|db|sqlite|log|sh|bak)$">
    Require all denied
</FilesMatch>

# セキュリティヘッダー
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHPの設定
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>

# ============================================================
# キャッシュ設定 — ページ速度向上
# ============================================================

<IfModule mod_expires.c>
    ExpiresActive On

    # 画像ファイル: 1ヶ月キャッシュ
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"

    # CSSファイル: 1ヶ月キャッシュ
    ExpiresByType text/css "access plus 1 month"

    # JavaScriptファイル: 1ヶ月キャッシュ
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # フォントファイル: 1年キャッシュ
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/eot "access plus 1 year"

    # HTMLファイル: 1時間キャッシュ（動的コンテンツ）
    ExpiresByType text/html "access plus 1 hour"

    # デフォルト: 1日キャッシュ
    ExpiresDefault "access plus 1 day"
</IfModule>

# キャッシュコントロールヘッダー（Expiresが使えない場合のフォールバック）
<IfModule mod_headers.c>
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|css|js|woff2|woff|ttf|eot)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>
</IfModule>
